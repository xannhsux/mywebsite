/* ============================================
   SECTION A — HERO
   ============================================ */

.hero {
  position: relative;
  height: 100vh;
  width: 100%;
  overflow: hidden;
  background: var(--color-bg);
}

.hero__inner {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ---- Floating Photos ---- */

.hero__photos {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 1;
}

.hero__photo {
  position: absolute;
  border-radius: var(--radius-sm);
  box-shadow: var(--shadow-photo);
  overflow: hidden;
  will-change: transform, opacity;
  /* Idle bobbing animation */
  animation: hero-bob 6s var(--ease-in-out) infinite;
}

.hero__photo img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: grayscale(80%) contrast(0.95);
}

@keyframes hero-bob {
  0%, 100% {
    translate: 0 0;
  }
  50% {
    translate: 0 -3px;
  }
}

/* Disable bobbing for reduced-motion */
@media (prefers-reduced-motion: reduce) {
  .hero__photo {
    animation: none;
  }
}

/* ---- Title ---- */

.hero__text {
  position: relative;
  z-index: 2;
  text-align: center;
  pointer-events: none;
  user-select: none;
}

.hero__title {
  font-family: var(--font-sans);
  font-weight: var(--fw-thin);
  font-size: var(--fs-hero-title);
  letter-spacing: 0.12em;
  color: var(--color-text-primary);
  line-height: 1;
  margin-bottom: var(--space-md);
}

.hero__subtitle {
  font-family: var(--font-sans);
  font-weight: var(--fw-light);
  font-size: var(--fs-hero-subtitle);
  color: var(--color-text-secondary);
  letter-spacing: 0.04em;
}
